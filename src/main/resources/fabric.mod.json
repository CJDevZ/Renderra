{
  "schemaVersion": 1,
  "id": "renderra",
  "version": "${version}",
  "name": "Renderra",
  "description": "Video Playback Mod, which enables streaming and displaying videos directly within Minecraft, for both modded and Vanilla Clients.",
  "authors": [
    "CJDev"
  ],
  "contact": {},
  "license": "LGPL-3.0",
  "icon": "assets/renderra/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "eu.cj4.renderra.impl.Renderra"
    ],
    "client": [
      "eu.cj4.renderra.client.impl.VideoPlayerClient"
    ]
  },
  "mixins": [
    {
      "environment": "*",
      "config": "renderra.mixins.json"
    },
    {
      "environment": "client",
      "config": "renderra.client.mixins.json"
    }
  ],
  "accessWidener": "renderra.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "~${minecraft_version}",
    "polymer-resource-pack": "*",
    "polymer-virtual-entity": "*"
  },
  "suggests": {
    "axiom": ">=${axiom_version}"
  }
}
